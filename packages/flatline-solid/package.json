{
  "name": "@edo-w/flatline-solid",
  "type": "module",
  "exports": {
    ".": "./dist/src/index.js",
    "./*": "./dist/src/*.js"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/bun": "latest",
    "@typescript/native-preview": "^7.0.0-dev.20260409.1",
    "clsx": "^2.1.1",
    "cpx2": "^8.0.0",
    "rimraf": "^6.1.2",
    "storybook": "^10.3.5",
    "storybook-solidjs-vite": "^10.0.12",
    "vite": "^7.2.6",
    "vite-plugin-solid": "^2.11.12"
  },
  "scripts": {
    "clean": "rimraf dist",
    "fmt": "biome format --write",
    "lint": "biome check --write",
    "check": "tsgo",
    "dev": "storybook dev -p 6006",
    "build:storybook": "storybook build",
    "build:lib": "tsgo --build tsconfig.build.json",
    "build:css": "cpx \"src/**/*.css\" \"dist/src\"",
    "make": "pnpm run check && pnpm run build:lib && pnpm run build:css"
  },
  "dependencies": {
    "@kobalte/core": "^0.13.11",
    "solid-js": "^1.9.12"
  }
}
