{
  "name": "@edo-w/flatline-solid",
  "version": "0.3.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/edo-w/flatline.git"
  },
  "author": "https://github.com/juanka881",
  "type": "module",
  "exports": {
    ".": "./dist/index.js",
    "./button": "./dist/button/index.js",
    "./card": "./dist/card/index.js",
    "./checkbox": "./dist/checkbox/index.js",
    "./combobox": "./dist/combobox/index.js",
    "./dialog": "./dist/dialog/index.js",
    "./dropdown-menu": "./dist/dropdown-menu/index.js",
    "./input": "./dist/input/index.js",
    "./label": "./dist/label/index.js",
    "./progress-bar": "./dist/progress-bar/index.js",
    "./radio": "./dist/radio/index.js",
    "./select": "./dist/select/index.js",
    "./slider": "./dist/slider/index.js",
    "./spinner": "./dist/spinner/index.js",
    "./switch": "./dist/switch/index.js",
    "./table": "./dist/table/index.js",
    "./tabs": "./dist/tabs/index.js",
    "./textarea": "./dist/textarea/index.js",
    "./xstack": "./dist/xstack/index.js",
    "./ystack": "./dist/ystack/index.js",
    "./package.json": "./package.json"
  },
  "imports": {
    "#src/*": "./dist/src/*"
  },
  "files": [
    "./dist/*"
  ],
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "@tsdown/css": "^0.21.8",
    "@types/bun": "latest",
    "@typescript/native-preview": "^7.0.0-dev.20260409.1",
    "cpx2": "^8.0.0",
    "rimraf": "^6.1.2",
    "rollup-plugin-postcss": "^4.0.2",
    "storybook": "^10.3.5",
    "storybook-solidjs-vite": "^10.0.12",
    "tsdown": "^0.21.8",
    "unplugin-solid": "^1.0.0",
    "vite": "^7.2.6",
    "vite-plugin-solid": "^2.11.12"
  },
  "scripts": {
    "clean": "rimraf --glob dist storybook-static edo-w-flatline-solid-*.tgz",
    "fmt": "biome format --write",
    "lint": "biome check --write",
    "check": "tsgo",
    "test": "echo \"no tests\"",
    "dev": "storybook dev -p 6006",
    "build": "pnpm run build:lib && pnpm run build:storybook",
    "build:storybook": "storybook build",
    "build:lib": "tsdown && cpx \"src/style/*.css\" dist/style",
    "prepack": "pnpm run lint && pnpm run check && pnpm run build:lib",
    "pack": "npm pack"
  },
  "dependencies": {
    "@kobalte/core": "^0.13.11",
    "clsx": "^2.1.1",
    "solid-js": "^1.9.12"
  },
  "inlinedDependencies": {
    "clsx": "2.1.1"
  }
}
