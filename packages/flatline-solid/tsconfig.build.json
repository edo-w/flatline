{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"outDir": "dist",
		"declaration": true,
		"target": "esnext",
		"sourceMap": true,
		"inlineSources": true,
		"composite": true,
		"tsBuildInfoFile": "dist/tsconfig.tsbuildinfo",
		"noEmit": false,
		"emitDeclarationOnly": false,
		"allowImportingTsExtensions": false,
	},
	"include": ["src"],
	"exclude": ["src/**/*.stories.tsx"]
}
